{
  "manifest_version": 3,
  "name": "Google Scholar Metadata Extractor",
  "version": "1.1",
  "permissions": ["activeTab", "downloads", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://scholar.google.com/scholar?*"],
      "js": ["content.js"]
    }
  ]
}